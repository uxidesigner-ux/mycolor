{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "moi-style-analysis",
  "main": "src/index.js",
  "compatibility_date": "2026-06-24",
  "workers_dev": true,
  "ratelimits": [
    {
      "name": "ANALYSIS_RATE_LIMITER",
      "namespace_id": "41001",
      "simple": {
        "limit": 20,
        "period": 60
      }
    }
  ],
  "vars": {
    "ALLOWED_ORIGINS": "https://uxidesigner-ux.github.io,http://localhost:4173,http://127.0.0.1:4173",
    "OPENAI_MODEL": "gpt-5.4-mini"
  }
}
